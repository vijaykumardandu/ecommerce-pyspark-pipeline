# E-Commerce PySpark Pipeline — Interactive Walkthrough

Run each cell in order to execute the full pipeline and explore the output tables.

**Requirements:** Java 11+, Python 3.10+, all packages from `requirements.txt`
import sys, os
# Add project root to path
project_root = os.path.abspath(os.path.join(os.getcwd(), '..'))
if project_root not in sys.path:
    sys.path.insert(0, project_root)
print('Project root:', project_root)
## Step 1 — Generate Synthetic Data
from src.generate_data import main as generate_data
generate_data()
## Step 2 — Bronze Layer (Raw Ingestion)
from src.bronze_ingest import run_bronze
run_bronze()
from src.utils import get_spark
from config.settings import BRONZE_PATH

spark = get_spark()
bronze_df = spark.read.format('delta').load(BRONZE_PATH)
print(f'Bronze rows: {bronze_df.count():,}')
bronze_df.show(5, truncate=True)
## Step 3 — Silver Layer (Cleanse & Transform)
from src.silver_transform import run_silver
run_silver()
from config.settings import SILVER_PATH

silver_df = spark.read.format('delta').load(SILVER_PATH)
print(f'Silver rows: {silver_df.count():,}')
silver_df.select('order_id','amount','currency','amount_usd','order_date','region','channel').show(10)
## Step 4 — Data Quality Checks
from src.quality_checks import run_quality
run_quality()
from config.settings import QUALITY_LOG

qlog = spark.read.format('delta').load(QUALITY_LOG)
qlog.select('check_name','score','status','details').show(truncate=60)
## Step 5 — Gold Layer (Business Aggregates)
from src.gold_aggregate import run_gold
run_gold()
from config.settings import GOLD_PATH
from pyspark.sql import functions as F

gold_df = spark.read.format('delta').load(GOLD_PATH)
print(f'Gold rows: {gold_df.count():,}')

print('\n── Revenue by Channel ──')
gold_df.groupBy('channel').agg(
    F.round(F.sum('total_revenue'), 2).alias('revenue_usd'),
    F.sum('order_count').alias('orders')
).orderBy(F.desc('revenue_usd')).show()

print('\n── Revenue by Product Category ──')
gold_df.groupBy('product_category').agg(
    F.round(F.sum('total_revenue'), 2).alias('revenue_usd')
).orderBy(F.desc('revenue_usd')).show()
